PORT=4000
CORS_ORIGIN=http://localhost:3000

# Either use DATABASE_URL or the individual PG* settings below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lead_capture_agent
PGSSL=false

# OpenAI Responses API configuration.
# Without this key, the app uses a deterministic local fallback so the demo still works.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional: set to "fallback" to force local qualification during development.
AI_QUALIFICATION_MODE=
