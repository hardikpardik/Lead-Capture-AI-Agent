PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Either use DATABASE_URL or the individual PG* settings below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lead_capture_agent
PGSSL=false

# Set this in production so admin lead data is not public.
# Keep blank locally if you want the admin page to load without a token.
ADMIN_TOKEN=

# Google Gemini API configuration.
# Without this key, the app uses a deterministic local fallback so the demo still works.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Set to "fallback" to force local qualification and avoid API spend.
AI_QUALIFICATION_MODE=fallback
